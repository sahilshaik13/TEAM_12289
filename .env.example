APP_NAME=EchoMemory
APP_VERSION=1.0.0
DEBUG=false

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DATABASE?sslmode=require

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

JWT_SECRET=change_this_to_a_random_256_bit_secret

GCS_BUCKET=your-gcs-bucket-name
CLOUD_TASKS_QUEUE_PATH=projects/your-project/locations/asia-south1/queues/embedding-jobs
WORKER_URL=https://your-cloud-run-url.app

VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=asia-south1
VERTEX_AI_MODEL=text-embedding-004
